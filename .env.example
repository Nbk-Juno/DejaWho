# Required — used for embeddings, GPT-4o, Whisper, and TTS
OPENAI_API_KEY=sk-...

# Optional — higher-quality TTS voice. Falls back to OpenAI TTS if absent.
ELEVENLABS_API_KEY=

# Optional — Postgres connection string. Without it, the app uses in-memory storage.
DATABASE_URL=

# Optional — defaults to 5000
PORT=5000
