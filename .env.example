# Required — used for embeddings, GPT-4o, Whisper, and TTS
OPENAI_API_KEY=

# Optional — higher-quality TTS voice. Falls back to OpenAI TTS if absent.
ELEVENLABS_API_KEY=

# Postgres connection string. For local development run `docker compose up -d`
# then use postgresql://who_that:who_that_dev@localhost:54322/who_that. In
# production, paste the Supabase project's pooled connection string.
DATABASE_URL=

# Test database. Tests truncate all tables between runs — do NOT point this at
# data you care about. Falls back to DATABASE_URL if unset.
TEST_DATABASE_URL=

# Optional — defaults to 5000
PORT=5000

# Supabase Auth — required once auth is wired up. Grab these from the Supabase
# dashboard: Project Settings → API.
#   - SUPABASE_URL: Project URL
#   - SUPABASE_ANON_KEY: anon/public key (safe to expose to the client)
#   - SUPABASE_SERVICE_ROLE_KEY: server-only, bypasses RLS — never ship to client
#   - SUPABASE_JWT_SECRET: server-only, used to verify Bearer tokens
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Vite-exposed Supabase keys for the browser client. Mirror the server-side
# values above. Anon key is safe to ship to the client; never expose the
# service role or JWT secret here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local Postgres credentials for docker compose. Defaults match the connection
# string in DATABASE_URL above; override only if you want to share a host.
POSTGRES_USER=who_that
POSTGRES_PASSWORD=who_that_dev
POSTGRES_DB=who_that
